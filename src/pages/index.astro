---
import Terminal from '../components/Terminal.tsx';
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  
    <!-- Primary Meta Tags -->
    <title>Emre Tolga Kaptan - Backend Developer | Interactive Terminal Portfolio</title>
    <meta name="title" content="Emre Tolga Kaptan - Backend Developer | Interactive Terminal Portfolio" />
    <meta name="description" content="Backend-focused Software Developer with experience in Go, TypeScript, and PostgreSQL. Built REST APIs, authentication systems, and scalable applications. Seeking Backend Internship in Poland." />
    <meta name="keywords" content="Backend Developer, Go, TypeScript, PostgreSQL, REST API, Software Engineer, Poland, Internship, Docker, JWT Authentication" />
    <meta name="author" content="Emre Tolga Kaptan" />
    <meta name="robots" content="index, follow" />
    <meta name="language" content="English" />
  
    <!-- Canonical URL -->
    <link rel="canonical" href="https://your-domain.com" />
  
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://your-domain.com" />
    <meta property="og:title" content="Emre Tolga Kaptan - Backend Developer | Interactive Terminal Portfolio" />
    <meta property="og:description" content="Backend-focused Software Developer with experience in Go, TypeScript, and PostgreSQL. Built REST APIs, authentication systems, and scalable applications. Seeking Backend Internship in Poland." />
    <meta property="og:image" content="https://your-domain.com/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Emre Tolga Kaptan - Backend Developer Terminal Portfolio" />
    <meta property="og:site_name" content="Emre Tolga Kaptan Portfolio" />
    <meta property="og:locale" content="en_US" />
  
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://your-domain.com" />
    <meta property="twitter:title" content="Emre Tolga Kaptan - Backend Developer | Interactive Terminal Portfolio" />
    <meta property="twitter:description" content="Backend-focused Software Developer with experience in Go, TypeScript, and PostgreSQL. Built REST APIs, authentication systems, and scalable applications. Seeking Backend Internship in Poland." />
    <meta property="twitter:image" content="https://your-domain.com/og-image.png" />
    <meta property="twitter:image:alt" content="Emre Tolga Kaptan - Backend Developer Terminal Portfolio" />
  
    <!-- Favicons and App Icons -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0A0E14" />
    <meta name="msapplication-TileColor" content="#0A0E14" />
  
    <!-- Preconnect for Performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap" rel="stylesheet" />
  
    <!-- Schema.org JSON-LD for SEO -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Emre Tolga Kaptan",
        "alternateName": "Emre T. Kaptan",
        "url": "https://your-domain.com",
        "image": "https://your-domain.com/og-image.png",
        "sameAs": [
          "https://linkedin.com/in/emre-t-kaptan",
          "https://github.com/Tikkaaa3"
        ],
        "jobTitle": "Backend Developer",
        "worksFor": {
          "@type": "Organization",
          "name": "Seeking Opportunities"
        },
        "alumniOf": "WSB Merito University",
        "email": "tikkaaa3@gmail.com",
        "telephone": "+48452014231",
        "address": {
          "@type": "PostalAddress",
          "addressCountry": "Poland"
        },
        "knowsAbout": [
          "Backend Development",
          "Go Programming Language",
          "TypeScript",
          "PostgreSQL",
          "REST APIs",
          "Docker",
          "Authentication Systems"
        ],
        "description": "Backend-focused Software Developer with experience in Go, TypeScript, and PostgreSQL. Built REST APIs, authentication systems, and scalable applications."
      }
    </script>
  </head>
  <body class="h-full m-0 p-0 overflow-hidden bg-[#0A0E14]" style="font-family: 'JetBrains Mono', monospace;">
    <div id="terminal-container" class="h-full w-full">
      <Terminal client:load />
    </div>
  </body>
</html>

<style>
  html, body {
    height: 100vh;
    width: 100vw;
    margin: 0;
    padding: 0;
    font-family: 'JetBrains Mono', monospace;
    background-color: #0A0E14;
    overflow: hidden;
  }
  
  /* Hide scrollbars globally while keeping functionality */
  * {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  
  *::-webkit-scrollbar {
    display: none;
  }
  
  /* Ensure no unwanted margins or padding */
  #terminal-container {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>
